{
  "name": "featurehub-node-example",
  "version": "2.1.0",
  "main": "index.js",
  "module": "index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "clean": "rimraf node_modules dist",
    "setup": "pnpm link ../../packages/js ../../packages/node",
    "compile": "pnpm run setup && pnpm run build",
    "serve": "node --trace-deprecation --trace-warnings dist/app.cjs ",
    "otel": "OTEL_USAGE_ENABLED=true node --trace-deprecation --trace-warnings --import ./otel/instrumentation.mjs dist/app.cjs ",
    "segment": "SEGMENT_ENABLED=true node --trace-deprecation --trace-warnings dist/app.cjs ",
    "start": "pnpm run build && pnpm run serve",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.70.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "@segment/analytics-node": "^2.3.0",
    "dotenv": "^17.3.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "featurehub-javascript-node-sdk": "workspace:*",
    "featurehub-usage-opentelemetry": "workspace:*",
    "featurehub-usage-segment": "workspace:*"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "catalog:node",
    "featurehub-tsconfig": "workspace:*",
    "rimraf": "catalog:rimraf",
    "ts-node": "10.9.2",
    "tsup": "catalog:tsup",
    "typescript": "catalog:typescript",
    "vite": "7.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.18.3"
}
