{
  "name": "featurehub-react-sdk",
  "version": "2.0.1",
  "description": "The React SDK for FeatureHub",
  "private": false,
  "author": "info@featurehub.io",
  "license": "MIT",
  "homepage": "https://featurehub.io",
  "repository": "github:featurehub-io/featurehub-javascript-sdk",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf node_modules dist",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "react18": "pnpm install && pnpm run build && rm -rf node_modules/react node_modules/react-dom node_modules/@types/react-dom node_modules/@types/react"
  },
  "peerDependencies": {
    "featurehub-javascript-client-sdk": "workspace:^",
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "catalog:node",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "featurehub-javascript-client-sdk": "workspace:^",
    "featurehub-tsconfig": "workspace:*",
    "jsdom": "^27.1.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "rimraf": "catalog:rimraf",
    "tsup": "catalog:tsup",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite",
    "vitest": "catalog:vitest"
  },
  "keywords": [
    "feature-flag-api",
    "feature-flag-sdk",
    "feature-flag-react",
    "react-feature-flag",
    "feature-experimentation",
    "feature-flag",
    "flag",
    "toggle",
    "feature-toggle",
    "feature-toggle-api",
    "remote-configuration",
    "gradual-rollout",
    "ab-testing",
    "featurehub",
    "featurehub-react"
  ],
  "packageManager": "pnpm@10.18.3"
}
