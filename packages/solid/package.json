{
  "name": "featurehub-solid-sdk",
  "version": "2.0.1",
  "description": "The Solid SDK for FeatureHub",
  "private": false,
  "author": "info@featurehub.io",
  "license": "MIT",
  "homepage": "https://featurehub.io",
  "repository": "github:featurehub-io/featurehub-javascript-sdk",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf node_modules dist",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "peerDependencies": {
    "featurehub-javascript-client-sdk": "workspace:^",
    "solid-js": ">=1.6.8"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "catalog:node",
    "featurehub-javascript-client-sdk": "workspace:^",
    "featurehub-tsconfig": "workspace:*",
    "jsdom": "^27.1.0",
    "rimraf": "catalog:rimraf",
    "solid-js": "^1.9.7",
    "tsup": "catalog:tsup",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "catalog:vitest"
  },
  "keywords": [
    "feature-flag-api",
    "feature-flag-sdk",
    "feature-flag-react",
    "feature-experimentation",
    "feature-flag",
    "flag",
    "toggle",
    "feature-toggle",
    "feature-toggle-api",
    "remote-configuration",
    "gradual-rollout",
    "ab-testing",
    "featurehub",
    "featurehub-solid",
    "solid-feature-flag",
    "solidjs-feature-flag"
  ],
  "packageManager": "pnpm@10.18.3",
  "browser": {},
  "typesVersions": {}
}
